# -- Local Development (SQLite) --
# Change schema.prisma provider to "sqlite" for local dev
# DATABASE_URL="file:./dev.db"

# -- Production (PostgreSQL) --
DATABASE_URL="postgresql://user:password@host:5432/taskflow?sslmode=require"

# Generate strong secrets with PowerShell:
# [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Max 256 }) -as [byte[]])
JWT_SECRET="CHANGE_ME_TO_64_CHAR_RANDOM_STRING"
JWT_REFRESH_SECRET="CHANGE_ME_TO_ANOTHER_64_CHAR_RANDOM_STRING"

PORT=3001
CLIENT_URL="http://localhost:5173"
