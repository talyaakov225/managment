generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  password   String
  avatar     String?
  globalRole  String    @default("USER") // SUPER_ADMIN, ADMIN, USER
  isApproved  Boolean   @default(false)
  seeAllTasks Boolean   @default(false)
  lastSeen    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  ownedProjects    Project[]
  memberships      ProjectMember[]
  createdTasks     Task[]           @relation("TaskCreator")
  taskAssignments  TaskAssignee[]
  comments         Comment[]
  userRoles        UserRole[]
  auditLogs        AuditLog[]
  chatMembers      ChatMember[]
  chatMessages     ChatMessage[]
  messageReactions MessageReaction[]
  pinnedMessages   ChatMessage[]    @relation("PinnedBy")
  notifications    Notification[]
  reminders        ChatReminder[]   @relation("ReminderCreator")
  targetReminders  ChatReminder[]   @relation("ReminderTarget")
  taskActivities   TaskActivity[]
  favorites        Favorite[]
  stickyNotes      StickyNote[]
  reminders2       Reminder[]
  teamMemberships  TeamMember[]
  loginLogs        LoginLog[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  members   ProjectMember[]
  tasks     Task[]
  favorites Favorite[]
}

model ProjectMember {
  id   String @id @default(cuid())
  role String @default("MEMBER")

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  color       String?
  position    Int       @default(0)
  dueDate     DateTime?
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creatorId  String?
  creator    User?   @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  assignees      TaskAssignee[]
  comments       Comment[]
  chatMessages   ChatMessage[]
  subtasks       Subtask[]
  activities     TaskActivity[]
  tags           TaskTag[]
  timeEntries    TimeEntry[]
  dependsOn      TaskDependency[] @relation("DependentTask")
  dependedBy     TaskDependency[] @relation("DependencyTask")
  templateId     String?
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskAssignee {
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String   @default("EDITOR")
  assignedAt DateTime @default(now())

  @@id([taskId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  taskId   String
  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId String
  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ── Dynamic Role & Permission System ──

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  color       String   @default("#6366f1")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  group       String
  displayName String

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ── Board Configuration ──

model BoardStatus {
  id        String  @id @default(cuid())
  key       String  @unique
  label_he  String
  label_en  String
  color     String
  bgColor   String
  position  Int     @default(0)
  isDefault Boolean @default(false)
}

model BoardPriority {
  id       String @id @default(cuid())
  key      String @unique
  label_he String
  label_en String
  color    String
  dotColor String
  position Int    @default(0)
}

model Category {
  id       String @id @default(cuid())
  name     String
  color    String @default("#6366f1")
  position Int    @default(0)

  tasks Task[]
}

// ── Navigation & CMS Pages ──

model NavItem {
  id                 String    @id @default(cuid())
  label_he           String
  label_en           String
  icon               String    @default("FileText")
  href               String
  position           Int       @default(0)
  visible            Boolean   @default(true)
  parentId           String?
  parent             NavItem?  @relation("NavChildren", fields: [parentId], references: [id])
  children           NavItem[] @relation("NavChildren")
  requiredPermission String?
}

model CustomPage {
  id                 String      @id @default(cuid())
  slug               String      @unique
  title_he           String
  title_en           String
  description        String?
  isPublished        Boolean     @default(false)
  requiredPermission String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  blocks PageBlock[]
}

model PageBlock {
  id       String @id @default(cuid())
  type     String
  content  String
  position Int    @default(0)
  settings String @default("{}")

  pageId String
  page   CustomPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

// ── Chat System ──

model ChatChannel {
  id          String   @id @default(cuid())
  name        String
  description String?
  isGeneral   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   ChatMember[]
  messages  ChatMessage[]
  reminders ChatReminder[]
}

model ChatMember {
  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime    @default(now())
  lastRead  DateTime    @default(now())

  @@id([channelId, userId])
}

model ChatMessage {
  id        String    @id @default(cuid())
  content   String
  type      String    @default("user") // user, bot, system
  editedAt  DateTime?
  isDeleted Boolean   @default(false)
  isPinned  Boolean   @default(false)
  pinnedAt  DateTime?
  pinnedById String?
  pinnedBy   User?    @relation("PinnedBy", fields: [pinnedById], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())

  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  taskId    String?
  task      Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  replyToId String?
  replyTo   ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[] @relation("MessageReplies")

  reactions   MessageReaction[]
  attachments MessageAttachment[]
}

model MessageAttachment {
  id           String @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String

  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model ChatReminder {
  id        String   @id @default(cuid())
  message   String
  triggerAt DateTime
  triggered Boolean  @default(false)
  createdAt DateTime @default(now())

  channelId    String
  channel      ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId       String
  user         User @relation("ReminderCreator", fields: [userId], references: [id], onDelete: Cascade)
  targetUserId String?
  targetUser   User?  @relation("ReminderTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
}

model MessageReaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())

  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

// ── Task Activity Log ──

model TaskActivity {
  id        String   @id @default(cuid())
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Favorites ──

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

// ── Notifications ──

model Notification {
  id        String   @id @default(cuid())
  type      String   // task_assigned, chat_message, task_comment, etc.
  title     String
  body      String
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkUrl   String?
  createdAt DateTime @default(now())
}

// ── Sticky Notes ──

model StickyNote {
  id        String   @id @default(cuid())
  content   String   @default("")
  color     String   @default("#fef08a")
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Personal Reminders ──

model Reminder {
  id        String   @id @default(cuid())
  title     String
  content   String?
  color     String   @default("#3b82f6")
  triggerAt DateTime
  triggered Boolean  @default(false)
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── System Settings & Audit Log ──

model SystemSetting {
  id       String  @id @default(cuid())
  key      String  @unique
  value    String
  type     String  @default("string")
  group    String  @default("general")
  label_he String?
  label_en String?
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  details   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ipAddress String?
  createdAt DateTime @default(now())
}

// ── Tags ──

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6366f1")

  tasks TaskTag[]
}

model TaskTag {
  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

// ── Task Templates ──

model TaskTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  priority    String   @default("MEDIUM")
  color       String?
  createdAt   DateTime @default(now())
  creatorId   String

  subtasks TemplateSubtask[]
  tags     String[] @default([])
}

model TemplateSubtask {
  id       String @id @default(cuid())
  title    String
  position Int    @default(0)

  templateId String
  template   TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// ── Time Tracking ──

model TimeEntry {
  id        String    @id @default(cuid())
  startTime DateTime
  endTime   DateTime?
  duration  Int?
  note      String?
  createdAt DateTime  @default(now())

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
}

// ── Login Log ──

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

// ── Task Dependencies ──

model TaskDependency {
  id           String @id @default(cuid())
  type         String @default("blocks") // blocks, blocked_by

  taskId       String
  task         Task @relation("DependentTask", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnId  String
  dependsOn    Task @relation("DependencyTask", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
}

// ── Teams ──

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())

  members TeamMember[]
}

model TeamMember {
  teamId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   String @default("MEMBER")

  @@id([teamId, userId])
}
